{
  "info": {
    "_postman_id": "7e2f09e6-ef2c-4ef5-9f28-easyclubsport-api",
    "name": "EasyClubSport API",
    "description": "Collection Postman pour tester l'API actuelle de EasyClubSport. Le token est enregistre automatiquement apres la connexion dans la variable de collection token_api.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token_api}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    { "key": "base_url", "value": "http://127.0.0.1:8000/api" },
    { "key": "token_api", "value": "" },
    { "key": "club_id", "value": "1" },
    { "key": "equipe_id", "value": "1" },
    { "key": "coach_id", "value": "1" },
    { "key": "joueur_id", "value": "1" }
  ],
  "item": [
    {
      "name": "1. Authentification",
      "item": [
        {
          "name": "Inscription President",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nom\": \"El Idrissi\",\n  \"prenom\": \"Hamza\",\n  \"email\": \"president@example.com\",\n  \"password\": \"password123\",\n  \"password_confirmation\": \"password123\",\n  \"telephone\": \"0612345678\",\n  \"adresse\": \"Safi\",\n  \"role\": \"president\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/inscription",
              "host": ["{{base_url}}"],
              "path": ["auth", "inscription"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "if (data?.data?.utilisateur?.id) pm.collectionVariables.set('president_id', String(data.data.utilisateur.id));"
                ]
              }
            }
          ]
        },
        {
          "name": "Inscription Coach",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nom\": \"Coach\",\n  \"prenom\": \"Youssef\",\n  \"email\": \"coach@example.com\",\n  \"password\": \"password123\",\n  \"password_confirmation\": \"password123\",\n  \"telephone\": \"0622222222\",\n  \"adresse\": \"Casablanca\",\n  \"role\": \"coach\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/inscription",
              "host": ["{{base_url}}"],
              "path": ["auth", "inscription"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "if (data?.data?.utilisateur?.id) pm.collectionVariables.set('coach_id', String(data.data.utilisateur.id));"
                ]
              }
            }
          ]
        },
        {
          "name": "Inscription Joueur",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nom\": \"Joueur\",\n  \"prenom\": \"Amine\",\n  \"email\": \"joueur@example.com\",\n  \"password\": \"password123\",\n  \"password_confirmation\": \"password123\",\n  \"telephone\": \"0633333333\",\n  \"adresse\": \"Marrakech\",\n  \"role\": \"joueur\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/inscription",
              "host": ["{{base_url}}"],
              "path": ["auth", "inscription"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "if (data?.data?.utilisateur?.id) pm.collectionVariables.set('joueur_id', String(data.data.utilisateur.id));"
                ]
              }
            }
          ]
        },
        {
          "name": "Connexion President",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"president@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/connexion",
              "host": ["{{base_url}}"],
              "path": ["auth", "connexion"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "if (data?.data?.token) {",
                  "  pm.collectionVariables.set('token_api', data.data.token);",
                  "}",
                  "if (data?.data?.utilisateur?.id) {",
                  "  pm.collectionVariables.set('president_id', String(data.data.utilisateur.id));",
                  "}",
                  "pm.test('Token enregistre', function () {",
                  "  pm.expect(pm.collectionVariables.get('token_api')).to.not.eql('');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Moi",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/auth/moi",
              "host": ["{{base_url}}"],
              "path": ["auth", "moi"]
            }
          }
        },
        {
          "name": "Deconnexion",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/auth/deconnexion",
              "host": ["{{base_url}}"],
              "path": ["auth", "deconnexion"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.collectionVariables.unset('token_api');"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "2. Profil President",
